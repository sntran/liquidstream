{
  "name": "@sntran/liquidstream",
  "version": "0.2.0",
  "description": "A lightweight Liquid subset renderer built on HTMLRewriter for Cloudflare Workers and Node.js.",
  "type": "module",
  "main": "./lib/mod.js",
  "exports": {
    ".": "./lib/mod.js",
    "./jekyll": "./lib/plugins/jekyll.js"
  },
  "files": [
    "lib",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sntran/liquidstream.git"
  },
  "homepage": "https://github.com/sntran/liquidstream/",
  "bugs": {
    "url": "https://github.com/sntran/liquidstream/issues"
  },
  "license": "MIT",
  "scripts": {
    "start": "npx -y wrangler pages dev .",
    "test": "node scripts/run-tests.mjs",
    "build": "esbuild lib/mod.js --bundle --format=esm --outfile=dist/liquidstream.js --sourcemap --target=es2020 --platform=node && esbuild lib/mod.js --bundle --format=esm --outfile=dist/liquidstream.min.js --sourcemap --minify --target=es2020 --platform=node",
    "coverage": "c8 --reporter=text --include=lib/mod.js node scripts/run-tests.mjs",
    "benchmark": "node --expose-gc --experimental-wasm-jspi scripts/benchmark-liquid.mjs"
  },
  "keywords": [
    "liquid",
    "htmlrewriter",
    "cloudflare-workers",
    "streaming",
    "template-engine"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sntran/html-rewriter": "github:sntran/html-rewriter"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "esbuild": "^0.27.4",
    "fast-check": "^4.6.0",
    "liquidjs": "^10.25.0",
    "marked": "^16.4.0"
  }
}
